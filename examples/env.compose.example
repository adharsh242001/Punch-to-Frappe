# Copy this file to .env beside docker-compose.yml on the Docker server.
# Docker Compose reads this file for port/auth settings.

# Public port for Nginx. The Python app stays internal on container port 8080.
DASHBOARD_PORT=8090

# Browser login for the dashboard and /api routes.
# /events stays open to edge PCs and is still protected by HMAC signatures.
NGINX_BASIC_AUTH_USER=admin
NGINX_BASIC_AUTH_PASSWORD=change_this_dashboard_password
