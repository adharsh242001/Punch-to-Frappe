# Copy this file to .env.server on the Ubuntu Docker server.
# Do not commit .env.server.

HRMS_URL=https://your-frappe-site.example.com
HRMS_API_KEY=your_frappe_api_key
HRMS_API_SECRET=your_frappe_api_secret

EMPLOYEE_MAP=/app/employee_map.json
STORAGE_BACKEND=postgres
POSTGRES_DSN=postgresql://punch_sync:change_this_postgres_password@postgres:5432/punch_sync

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_NODE_KEYS=pc-a:change_this_to_a_long_random_secret_for_pc_a,pc-b:change_this_to_a_long_random_secret_for_pc_b

POLL_INTERVAL=600
DEDUP_WINDOW=30
DEFAULT_LOG_TYPE=IN
LOG_LEVEL=INFO
# Leave empty in Docker so logs go to stdout and can be read with docker logs.
LOG_FILE=
