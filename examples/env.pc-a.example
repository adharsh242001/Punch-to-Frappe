# Copy this file to .env on PC A.
# Put only the punch devices PC A can reach in DEVICES.

DEVICES=10.10.10.166,10.10.10.128
DEVICE_USER=admin
DEVICE_PASS=your_device_password

SYNC_SERVER_URL=http://central-server-ip:8090
EDGE_NODE_ID=pc-a
EDGE_NODE_SECRET=change_this_to_a_long_random_secret_for_pc_a

POLL_INTERVAL=600
FIRST_RUN_LOOKBACK_HOURS=24
LOG_LEVEL=INFO
LOG_FILE=data/edge-agent.log
