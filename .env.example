# ─────────────────────────────────────────────────────────────────────────────
# Attendance Sync Service — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of Hikvision device IPs
DEVICES=10.10.10.131,10.10.10.166

# Credentials shared by all devices
DEVICE_USER=admin
DEVICE_PASS=your_device_password

# Frappe HRMS base URL (no trailing slash)
HRMS_URL=https://hrms.example.com

# Frappe API credentials (Settings → My Account → API Access)
HRMS_API_KEY=your_api_key
HRMS_API_SECRET=your_api_secret

# ── optional tunables ─────────────────────────────────────────────────────────

# Poll interval in seconds (default: 10)
# POLL_INTERVAL=10

# Duplicate-punch suppression window in seconds (default: 30)
# DEDUP_WINDOW=30

# Event type filter (default: major=5, minor=75 — face recognition)
# EVENT_MAJOR=5
# EVENT_MINOR=75

# Path to employee map JSON (default: ./employee_map.json)
# EMPLOYEE_MAP=employee_map.json

# SQLite database path (default: ./data/events.db)
# STORE_PATH=data/events.db

# Retry queue settings
# RETRY_MAX_ATTEMPTS=5
# RETRY_BACKOFF_BASE=2.0

# Logging: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Optional log file (default: stdout only)
# LOG_FILE=logs/attendance_sync.log
